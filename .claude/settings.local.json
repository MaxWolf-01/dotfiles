{
  "permissions": {
    "allow": [
      "mcp__rime",
      "Bash(git clone *)",
      "Bash(tailscale serve *)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledPlugins": {
    "plugin-dev@claude-plugins-official": true
  },
  "outputStyle": "default",
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": false
  },
  "spinnerTipsEnabled": false,
  "prefersReducedMotion": true
}
