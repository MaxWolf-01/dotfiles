# Yazi wrapper: in tmux, launches in a standalone Ghostty window to avoid
# KGP crash (ghostty-org/ghostty#4266). Otherwise uses yazi's cd-on-exit wrapper.
function y() {
  if [[ -n "$TMUX" ]]; then
    ghostty -e yazi "$@" &!
  else
    _yazi "$@"
  fi
}

# `o` with no arguments opens the current directory, otherwise opens the given location
function o() {
  local target="${1:-.}"
  if [[ -d "$target" ]]; then
    y "$target"
  else
    xdg-open "$target"
  fi
}

