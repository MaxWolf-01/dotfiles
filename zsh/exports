export EDITOR="${commands[nvim]:-vim}"

export PATH=~/bin:${PATH}
export PATH=~/.local/bin:${PATH}
export PATH=~/.claude/local:${PATH}
export PATH=~/.dotfiles/secrets/bin:${PATH}
export PATH=/usr/local/bin:${PATH}
export PATH=~/.npm-global/bin:$PATH
export PATH=$PATH:$HOME/go/bin
export PATH=~/.nix-profile/bin:${PATH}

export KITTY_CONFIG_DIRECTORY=~/.dotfiles/kitty

# Make Python use UTF-8 encoding for output to stdin, stdout, and stderr. (Redundant as of Python 3?)
export PYTHONIOENCODING='UTF-8'

export FZF_COMPLETION_TRIGGER='**'

export HYDRA_FULL_ERROR=1

export PYTHONBREAKPOINT=ipdb.set_trace
export PYTHONSTARTUP=~/.pythonrc

[[ -f ~/.local_exports ]] && source ~/.local_exports

