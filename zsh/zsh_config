# Ensure emacs-style line editing works in tmux
bindkey -e
bindkey "^A" beginning-of-line  # Ctrl+a (needs Ctrl+a Ctrl+a in tmux)
bindkey "^Q" beginning-of-line  # Ctrl+q (single key alternative)
bindkey "^E" end-of-line

# https://zsh.sourceforge.io/Doc/Release/Options.html
setopt autocd
setopt notify
setopt complete_aliases
unsetopt beep caseglob