#!/bin/bash

install_apt_packages() {
  apt-get update
  apt-get install -y \
    curl \
    git \
    htop \
    make \
    neofetch \
    rsync \
    openssh \
    tree \
    vim \
    wget \
    zsh
}

setup_zsh() {
  zsh zap_zsh_install             # minimal zsh plugin manager
  chsh -s "$(which zsh)" "$USER" # set zsh as default shell
}

install_theme() {
  curl -sSL "https://github.com/zthxxx/jovial/raw/master/jovial.zsh-theme" -o ~/jovial.zsh-theme
}

install_fzf() {
  # fuzzy finder
  git clone --depth 1 https://github.com/junegunn/fzf.git ~/.fzf
  ~/.fzf/install
}

echo "Setting ssh folder permissions..."
./bin/ssheperm
echo "Installing apt packages..."
install_apt_packages
echo "Setting up zsh..."
setup_zsh
echo "Installing fzf..."
install_fzf
echo "Installing theme..."
install_theme
