#!/usr/bin/env -S uv run --quiet --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["tyro"]
# ///
"""Batch-fetch into a common library directory via yapit.

Two modes:

  URLs — multiple URLs, each becomes a subdirectory::

    yoink-batch what-is-intelligence https://example.com/chapter-{01..10}
    yoink-batch my-book intro=https://example.com/prologue ch1=https://example.com/first

  Pages — one PDF/URL split by page ranges::

    yoink-batch textbook --source textbook.pdf \\
      ch1=1-30 ch2=31-55 ch3=56-80
    yoink-batch textbook --source https://example.com/book.pdf \\
      ch1=1-30 ch2=31-55

Names are inferred from the last URL path segment in URL mode.
Override with name=url. In pages mode, all entries must be name=pages.

Output structure::

    ~/Documents/library/<name>/
      <entry>/<entry>.md
      <entry>/<entry>-1.webp
      <entry>/TTS.md
"""

from __future__ import annotations

import os
import subprocess
import sys
from dataclasses import dataclass
from pathlib import Path
from typing import Annotated
from urllib.parse import urlparse

import tyro

LIBRARY = Path.home() / "Documents" / "library"
SOPS_FILE = Path.home() / ".dotfiles" / "secrets" / "passwords" / "yapit"


@dataclass
class Args:
    name: Annotated[str, tyro.conf.Positional]
    """Directory name under ~/Documents/library/."""

    entries: Annotated[list[str], tyro.conf.Positional]
    """URLs (or name=url). With --source: name=pages pairs (e.g. ch1=1-30)."""

    source: str | None = None
    """Single PDF path or URL to split by page ranges."""

    ai: bool = True
    """Pass --ai to yapit (AI extraction for PDFs). Use --no-ai to skip."""


def load_yapit_env() -> dict[str, str]:
    result = subprocess.run(
        ["sops", "-d", str(SOPS_FILE)],
        capture_output=True, text=True, check=True,
    )
    env = dict(os.environ)
    for line in result.stdout.strip().splitlines():
        if "=" in line:
            k, _, v = line.partition("=")
            env[k.strip()] = v.strip()
    return env


def infer_slug(url: str) -> str:
    path = urlparse(url).path.rstrip("/")
    return path.rsplit("/", 1)[-1] if path else ""


def main() -> None:
    args = tyro.cli(Args, description=__doc__)
    outdir = LIBRARY / args.name
    env = load_yapit_env()

    failed: list[str] = []
    for entry in args.entries:
        if "=" in entry:
            slug, _, value = entry.partition("=")
        elif args.source:
            print(f"error: with --source, entries must be name=pages (got {entry!r})", file=sys.stderr)
            sys.exit(1)
        else:
            slug = infer_slug(entry)
            value = entry

        if not slug:
            print(f"skip: could not infer name from {entry}", file=sys.stderr)
            failed.append(entry)
            continue

        cmd = ["yapit", "fetch"]
        if args.source:
            cmd.append(args.source)
            cmd.extend(["--pages", value])
        else:
            cmd.append(value)
        cmd.extend(["-o", str(outdir), "--name", slug])
        if args.ai:
            cmd.append("--ai")

        print(f":: {slug} <- {args.source or value}", file=sys.stderr)
        result = subprocess.run(cmd, env=env)
        if result.returncode != 0:
            failed.append(slug)

    if failed:
        print(f"failed: {' '.join(failed)}", file=sys.stderr)

    print(outdir)


if __name__ == "__main__":
    main()
