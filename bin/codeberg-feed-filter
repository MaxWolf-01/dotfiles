#!/usr/bin/env python3
"""Newsboat filter for Codeberg RSS feeds.

Rewrites generic titles like "lucidrains pushed to main at lucidrains/repo"
to show the commit message instead: "[repo] commit message here"
"""

import html
import re
import sys
import xml.etree.ElementTree as ET

NSMAP = {"content": "http://purl.org/rss/1.0/modules/content/"}


def extract_commit_msg(desc: str) -> str | None:
    """Extract commit message from Codeberg's HTML description."""
    text = html.unescape(desc)
    # Description format: <a href="...">hash</a>\nmessage
    # Strip HTML tags, then take everything after the commit hash line
    text = re.sub(r"<[^>]+>", "", text).strip()
    lines = text.split("\n", 1)
    if len(lines) > 1:
        return lines[1].strip()
    return None


def extract_repo(title: str) -> str | None:
    # "pushed to main at user/repo", "pushed tag X to user/repo",
    # "created branch X in user/repo", "created repository user/repo"
    m = re.search(r"(?:at|to|in) \w+/([\w.-]+)", title)
    if not m:
        m = re.search(r"\w+/([\w.-]+?)(?:#\d+)?$", title)
    return m.group(1) if m else None


def summarize_title(title: str) -> str | None:
    """Extract a short action from non-commit events."""
    # "pushed tag 0.1.5 to user/repo" -> "tag 0.1.5"
    m = re.search(r"pushed (tag \S+)", title)
    if m:
        return m.group(1)
    # "created branch foo in user/repo" -> "branch foo"
    m = re.search(r"created (branch \S+)", title)
    if m:
        return m.group(1)
    # "created repository user/repo"
    if "created repository" in title:
        return "new repo"
    # "merged pull request user/repo#3"
    m = re.search(r"(merged pull request \S+)", title)
    if m:
        return m.group(1)
    # "commented on pull request user/repo#3"
    m = re.search(r"(commented on pull request \S+)", title)
    if m:
        return m.group(1)
    return None


NOISE = re.compile(r"pushed tag |created branch |created repository ")


def rewrite(xml_bytes: bytes) -> bytes:
    ET.register_namespace("content", NSMAP["content"])
    ET.register_namespace("", "")
    root = ET.fromstring(xml_bytes)

    for channel in root.iter("channel"):
        to_remove = []
        for item in channel.findall("item"):
            title_el = item.find("title")
            desc_el = item.find("description")
            if title_el is None or desc_el is None:
                continue

            title_text = title_el.text or ""

            if NOISE.search(title_text):
                to_remove.append(item)
                continue

            repo = extract_repo(title_text)
            msg = extract_commit_msg(desc_el.text or "")

            if repo and msg:
                first_line = msg.split("\n")[0]
                if len(first_line) > 120:
                    first_line = first_line[:117] + "..."
                title_el.text = f"[{repo}] {first_line}"
            elif repo:
                summary = summarize_title(title_text)
                title_el.text = f"[{repo}] {summary or title_text}"

        for item in to_remove:
            channel.remove(item)

    return ET.tostring(root, encoding="unicode", xml_declaration=True).encode()


if __name__ == "__main__":
    sys.stdout.buffer.write(rewrite(sys.stdin.buffer.read()))
