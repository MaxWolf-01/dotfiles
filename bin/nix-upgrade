#!/usr/bin/env bash
# Upgrade nix on non-NixOS multi-user installs.
# On NixOS, nix is managed by the system config — use nswitch instead.
#
# Reads the pinned nixpkgs rev from ~/.dotfiles/flake.lock (run `nix flake
# update nixpkgs` first to get the version you want).

set -euo pipefail

PROFILE="/nix/var/nix/profiles/default"
NIX_ENV="$PROFILE/bin/nix-env"

if [[ $EUID -ne 0 ]]; then
    echo "error: must run as root (try: sudo nix-upgrade)" >&2
    exit 1
fi

if [[ ! -x "$NIX_ENV" ]]; then
    echo "error: $NIX_ENV not found — is this a multi-user nix install?" >&2
    exit 1
fi

lockfile="${HOME}/.dotfiles/flake.lock"
if [[ ! -f "$lockfile" ]]; then
    echo "error: $lockfile not found" >&2
    exit 1
fi

rev=$(jq -r '.nodes.nixpkgs.locked.rev' "$lockfile")
if [[ -z "$rev" || "$rev" == "null" ]]; then
    echo "error: could not read nixpkgs rev from $lockfile" >&2
    exit 1
fi

current=$("$PROFILE/bin/nix" --version 2>/dev/null | awk '{print $NF}')
echo "current: nix $current"
echo "nixpkgs: $rev"

"$NIX_ENV" --profile "$PROFILE" -f "https://github.com/NixOS/nixpkgs/archive/${rev}.tar.gz" -iA nix

new=$("$PROFILE/bin/nix" --version 2>/dev/null | awk '{print $NF}')
echo "upgraded: nix $current -> $new"

systemctl restart nix-daemon
echo "done."
