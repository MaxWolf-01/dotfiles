#!/usr/bin/env bash
# Audit YouTube archive: show what's archived, what's lost, per playlist.
#
# Usage: youtube-audit <playlist_file> <output_dir>
# Example: youtube-audit ~/.dotfiles/secrets/backup/playlists.txt ~/data/yt

set -uo pipefail

playlist_file="${1:-}"
output_dir="${2:-}"

if [ -z "$playlist_file" ] || [ -z "$output_dir" ]; then
    echo "Usage: $0 <playlist_file> <output_dir>"
    exit 1
fi

total_archived=0
total_lost=0

while IFS='|' read -r url format name; do
    [ -z "$url" ] && continue
    [ "${url:0:1}" = "#" ] && continue

    playlist_dir="$output_dir/$format/$name"
    archive_file="$playlist_dir/archive.txt"
    lost_file="$playlist_dir/lost.txt"

    archived=0
    [ -f "$archive_file" ] && archived=$(wc -l < "$archive_file")

    echo "=== $name ($format) ==="
    echo "  Archived: $archived videos"

    if [ -f "$lost_file" ] && [ -s "$lost_file" ]; then
        lost=$(wc -l < "$lost_file")
        echo "  Never captured: $lost videos"
        while IFS=' ' read -r date vid_id vid_url; do
            # Try to resolve title from filename if this ID was previously archived
            title=""
            if grep -q "youtube $vid_id" "$archive_file" 2>/dev/null; then
                match=$(find "$playlist_dir" -maxdepth 1 -name "*\[$vid_id\]*" -print -quit 2>/dev/null)
                if [ -n "$match" ]; then
                    title=$(basename "$match" | sed -E "s/ \[$vid_id\]\.[^.]+$//")
                fi
                echo "    $date  $vid_id  (archived) ${title:-$vid_url}"
            else
                echo "    $date  $vid_id  $vid_url"
            fi
        done < "$lost_file"
        total_lost=$((total_lost + lost))
    else
        echo "  Never captured: 0"
    fi

    total_archived=$((total_archived + archived))
    echo ""
done < "$playlist_file"

echo "=== Totals ==="
echo "  Archived: $total_archived"
echo "  Never captured: $total_lost"
