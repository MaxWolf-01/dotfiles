#!/usr/bin/env bash
# Check which archived YouTube videos are no longer available.
# Uses YouTube's oEmbed endpoint (no API key needed).
#
# Usage: youtube-check-gone <playlist_file> <output_dir> [--parallel N]
# Example: youtube-check-gone ~/.dotfiles/secrets/backup/playlists.txt ~/data/yt

set -uo pipefail

playlist_file="${1:-}"
output_dir="${2:-}"
parallel=20

shift 2 2>/dev/null || true
while [[ $# -gt 0 ]]; do
    case "$1" in
        --parallel) parallel="$2"; shift 2 ;;
        *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
done

if [ -z "$playlist_file" ] || [ -z "$output_dir" ]; then
    echo "Usage: $0 <playlist_file> <output_dir> [--parallel N]"
    echo "Checks archived videos against YouTube. Reports which are gone."
    exit 1
fi

check_video() {
    local vid_id="$1" playlist_dir="$2"
    local status
    status=$(curl -s -o /dev/null -w "%{http_code}" \
        "https://www.youtube.com/oembed?url=https://youtube.com/watch?v=${vid_id}" 2>/dev/null)
    if [ "$status" != "200" ]; then
        # Resolve title from filename
        local title=""
        local match
        match=$(find "$playlist_dir" -maxdepth 1 -name "*\[${vid_id}\]*" -print -quit 2>/dev/null)
        if [ -n "$match" ]; then
            title=$(basename "$match" | sed -E "s/ \[${vid_id}\]\.[^.]+$//")
        fi
        echo "${vid_id}|${title:-unknown}|${status}"
    fi
}
export -f check_video

total_gone=0
total_checked=0

while IFS='|' read -r url format name; do
    [ -z "$url" ] && continue
    [ "${url:0:1}" = "#" ] && continue

    playlist_dir="$output_dir/$format/$name"
    archive_file="$playlist_dir/archive.txt"

    if [ ! -f "$archive_file" ]; then
        echo "=== $name ($format) === SKIP (no archive.txt)"
        continue
    fi

    count=$(wc -l < "$archive_file")
    echo "=== $name ($format) === checking $count videos..."

    gone_file=$(mktemp)

    # Extract IDs and check in parallel
    sed 's/^youtube //' "$archive_file" | \
        xargs -P "$parallel" -I{} bash -c 'check_video "$1" "$2"' _ {} "$playlist_dir" \
        > "$gone_file"

    gone=$(wc -l < "$gone_file")
    total_checked=$((total_checked + count))

    if [ "$gone" -gt 0 ]; then
        total_gone=$((total_gone + gone))
        echo "  Gone: $gone / $count"
        while IFS='|' read -r vid_id title status; do
            echo "    [$status] $title  https://youtube.com/watch?v=$vid_id"
        done < "$gone_file"
    else
        echo "  All $count videos still available"
    fi

    rm -f "$gone_file"
    echo ""
done < "$playlist_file"

echo "=== Total: $total_gone gone out of $total_checked archived ==="
