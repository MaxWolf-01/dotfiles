#!/usr/bin/env bash
# Archive a webpage as markdown via defuddle.md
# Usage: archive <url>
set -euo pipefail

url="${1:?Usage: archive <url>}"
archive_dir="$HOME/Documents/archive/web"
filename="${url//[^a-zA-Z0-9]/_}.md"

mkdir -p "$archive_dir"
curl -sf "https://defuddle.md/$url" > "$archive_dir/$filename"
echo "$archive_dir/$filename"
