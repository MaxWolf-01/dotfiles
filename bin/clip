#!/usr/bin/env bash
# Copy file content or stdin to clipboard
# Usage: clip [file]    or    echo "text" | clip
set -euo pipefail

if [[ "$XDG_SESSION_TYPE" == "wayland" ]] || [[ -n "${WAYLAND_DISPLAY:-}" ]]; then
  copy_cmd="wl-copy"
else
  copy_cmd="xclip -selection clipboard"
fi

if [ -z "${1:-}" ]; then
  $copy_cmd
else
  $copy_cmd < "$1"
fi
