#!/usr/bin/env -S uv run --script --quiet
# /// script
# requires-python = ">=3.11"
# dependencies = ["tyro"]
# ///
"""Slugify text into URL/filesystem-safe strings.

Replaces non-alphanumeric runs with hyphens, lowercases, truncates to 100 chars.

Examples:

    slugify Hello, World!                # hello-world
    slugify "My Paper Title (2024)"      # my-paper-title-2024
    echo "some title" | slugify          # reads from stdin
"""

import re
import sys
from typing import Annotated

import tyro


def slugify(title: str) -> str:
    slug = re.sub(r"[^a-zA-Z0-9]+", "-", title).strip("-").lower()
    return slug[:250] or "untitled"


def main(
    words: Annotated[list[str], tyro.conf.Positional] = [],
) -> None:
    """Slugify text into a URL/filesystem-safe string.

    Args:
        words: Words to slugify. Reads from stdin if omitted.
    """
    text = " ".join(words) if words else sys.stdin.read().strip()
    print(slugify(text))


if __name__ == "__main__":
    tyro.cli(main)
