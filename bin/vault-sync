#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.13"
# ///
"""Sync whitelisted Obsidian vault notes + referenced media to Quartz.

Reads whitelist.json from the vault, copies matching files and any media
they reference to the Quartz content dir.

Env vars: VAULT_DIR, QUARTZ_DIR (both have sensible defaults).
"""

import fnmatch
import json
import os
import re
import shutil
import subprocess
import sys
from datetime import datetime
from pathlib import Path
from typing import TypedDict

HOME = Path.home()
VAULT_DIR_DEFAULT = HOME / "repos/obsidian/knowledge-base"
QUARTZ_DIR_DEFAULT = HOME / "repos/github/MaxWolf-01/quartz-knowledge-base"

MEDIA_EXTENSIONS = frozenset({
    ".jpg", ".jpeg", ".png", ".gif", ".webp", ".svg",
    ".mp4", ".webm", ".mov",
})

MAX_FILE_SIZE = 100 * 1024 * 1024  # TODO: remove once self-hosting (no GitHub file size limit)


class Whitelist(TypedDict):
    files: list[str]
    patterns: list[str]


def log(msg: str, level: str = "INFO") -> None:
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    print(f"[{ts}] {level}: {msg}")


def load_whitelist(path: Path) -> Whitelist:
    try:
        return json.loads(path.read_text())
    except FileNotFoundError:
        log("No whitelist.json found, creating empty one", "WARNING")
        wl: Whitelist = {"files": [], "patterns": []}
        path.write_text(json.dumps(wl, indent=2))
        return wl
    except json.JSONDecodeError as e:
        log(f"Error parsing whitelist.json: {e}", "ERROR")
        sys.exit(1)


def is_media(path: Path) -> bool:
    return path.suffix.lower() in MEDIA_EXTENSIONS


def extract_media_refs(markdown: str, file_path: str) -> set[str]:
    """Extract local media filenames referenced in markdown.

    Supports both Obsidian (![[img.png]], [[img.png]]) and standard
    markdown (![alt](img.png)) syntax. Skips URLs and code blocks.
    """
    # Strip code blocks and inline code
    text = re.sub(r"```[^`]*```", "", markdown, flags=re.DOTALL)
    text = re.sub(r"(?m)^( {4}|\t).*$\n?", "", text)
    text = re.sub(r"`[^`]+`", "", text)

    ext = r"\.(jpg|jpeg|png|gif|webp|svg|mp4|webm|mov)"
    patterns = [
        rf"!\[\[(.*?{ext}[^|\]]*?)(?:\|[^\]]+)?\]\]",  # ![[media|modifier]]
        rf"\[\[(.*?{ext}[^|\]]*?)(?:\|[^\]]+)?\]\]",    # [[media|modifier]]
        rf"!\[[^\]]*\]\(([^)]*?{ext})\)",                # ![alt](media.ext)
    ]

    names: set[str] = set()
    parent = Path(file_path).parent

    for pat in patterns:
        for m in re.finditer(pat, text, re.IGNORECASE):
            ref = m.group(1).strip()
            if ref.startswith(("http://", "https://")):
                continue
            resolved = (parent / ref).resolve() if not ref.startswith("/") else Path(ref)
            names.add(resolved.name)

    return names


def collect_referenced_media(
    source_dir: Path, whitelisted_files: list[str]
) -> set[str]:
    """Collect media filenames referenced by all whitelisted markdown files."""
    all_media: set[str] = set()

    for file_path in whitelisted_files:
        full_path = source_dir / file_path
        if not full_path.exists():
            log(f"File does not exist: {full_path}", "WARNING")
            continue
        if full_path.suffix.lower() != ".md":
            continue

        try:
            content = full_path.read_text(encoding="utf-8")
            media = extract_media_refs(content, file_path)
            if media:
                log(f"Found {len(media)} media refs in {file_path}")
            all_media.update(media)
        except Exception as e:
            log(f"Error processing {file_path}: {e}", "ERROR")

    return all_media


def is_whitelisted(
    file_path: str, whitelist: Whitelist, referenced_media: set[str]
) -> bool:
    if file_path in whitelist["files"]:
        return True

    if Path(file_path).name in referenced_media:
        return True

    for pattern in whitelist.get("patterns", []):
        if pattern.startswith("!"):
            if fnmatch.fnmatch(file_path, pattern[1:]):
                return False
        elif fnmatch.fnmatch(file_path, pattern):
            return True
    return False


def sync(source_dir: Path, content_dir: Path, whitelist: Whitelist) -> tuple[int, int]:
    # Report missing whitelisted files
    missing = {f for f in whitelist["files"] if not (source_dir / f).is_file()}
    if missing:
        log("Whitelisted files not found:", "WARNING")
        for f in sorted(missing):
            log(f"  - {f}", "WARNING")

    referenced_media = collect_referenced_media(source_dir, whitelist["files"])

    # Clean and recreate content dir
    if content_dir.exists():
        shutil.rmtree(content_dir)
    content_dir.mkdir(parents=True)
    media_dir = content_dir / "media"
    media_dir.mkdir()

    copied = 0
    skipped = 0

    # Copy whitelisted files from vault
    for source_path in source_dir.rglob("*", recurse_symlinks=True):
        if not source_path.is_file():
            continue

        rel = str(source_path.relative_to(source_dir))

        if not is_whitelisted(rel, whitelist, referenced_media):
            skipped += 1
            continue

        if source_path.stat().st_size > MAX_FILE_SIZE:
            log(f"Skipping (>{MAX_FILE_SIZE // 1024 // 1024}MB): {rel}", "WARNING")
            skipped += 1
            continue

        if is_media(source_path):
            target = media_dir / source_path.name
        else:
            target = content_dir / rel

        target.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(source_path, target)
        log(f"Copied: {rel}")
        copied += 1

    # Copy referenced media from external directories (library, archive)
    external_dirs = [
        HOME / "Documents" / "archive" / "papers",
        HOME / "Documents" / "library",
    ]
    for ext_dir in external_dirs:
        if not ext_dir.exists():
            continue
        log(f"Checking external directory for media: {ext_dir}")
        for path in ext_dir.rglob("*"):
            if path.is_file() and is_media(path) and path.name in referenced_media:
                target = media_dir / path.name
                if not target.exists():
                    if path.stat().st_size > MAX_FILE_SIZE:
                        log(f"Skipping (>{MAX_FILE_SIZE // 1024 // 1024}MB): {path.name}", "WARNING")
                        continue
                    shutil.copy2(path, target)
                    log(f"Copied external media: {path.name}")
                    copied += 1

    return copied, skipped


def _git(args: list[str], cwd: Path) -> str:
    return subprocess.run(
        ["git", "-C", str(cwd), *args],
        check=True, text=True, capture_output=True,
    ).stdout


def _blame_lines(repo: Path, rel_path: str) -> list[int]:
    """Return per-line unix epoch (author-time) for `rel_path` in `repo`.

    1-indexed; index 0 is a sentinel 0 so callers can use line numbers directly.
    """
    porcelain = _git(["blame", "--line-porcelain", "--", rel_path], repo)
    # Track current author-time, emit it on each new file_line (tab-prefixed content).
    out: list[int] = [0]
    cur_time = 0
    for line in porcelain.splitlines():
        if line.startswith("author-time "):
            cur_time = int(line.split(" ", 1)[1])
        elif line.startswith("\t"):
            out.append(cur_time)
    return out


def _head_sha(repo: Path) -> str:
    return _git(["rev-parse", "HEAD"], repo).strip()


def _changed_since(repo: Path, old_sha: str) -> set[str] | None:
    """Markdown paths changed between old_sha and HEAD. None if old_sha is unknown
    to the repo (forces a full recompute)."""
    try:
        out = _git(["diff", "--name-only", f"{old_sha}..HEAD"], repo)
    except subprocess.CalledProcessError:
        return None
    return {p for p in out.splitlines() if p.endswith(".md")}


def compute_blame(
    vault_dir: Path,
    whitelist: Whitelist,
    cache_path: Path,
) -> dict[str, list[int]]:
    """Build {vault-relative path: [per-line timestamps]} with HEAD-based caching.

    Cache stores the HEAD it was computed at plus per-file blame. On the next run:
    if HEAD is unchanged, reuse everything (no git calls). Otherwise re-blame only
    the markdown files that changed between the cached HEAD and the current one.
    Skips library/ (symlinked, not under git).
    """
    cache: dict = {}
    if cache_path.exists():
        try:
            cache = json.loads(cache_path.read_text())
        except Exception as e:
            log(f"Blame cache unreadable, starting fresh: {e}", "WARNING")

    cached_head = cache.get("head")
    cached_blame: dict[str, list[int]] = cache.get("blame", {})
    head = _head_sha(vault_dir)

    candidates = [
        rel
        for rel in whitelist["files"]
        if rel.endswith(".md")
        and not rel.startswith("library/")
        and (vault_dir / rel).is_file()
    ]

    # Decide which files need (re)blaming.
    if cached_head == head and cached_blame:
        to_blame: set[str] = {rel for rel in candidates if rel not in cached_blame}
    else:
        changed = _changed_since(vault_dir, cached_head) if cached_head else None
        if changed is None:
            to_blame = set(candidates)  # full recompute
        else:
            to_blame = {rel for rel in candidates if rel in changed or rel not in cached_blame}

    blame_map: dict[str, list[int]] = {}
    computed = 0
    for rel in candidates:
        if rel in to_blame:
            try:
                blame_map[rel] = _blame_lines(vault_dir, rel)
                computed += 1
            except subprocess.CalledProcessError as e:
                log(f"blame failed for {rel}: {e.stderr.strip()}", "WARNING")
        elif rel in cached_blame:
            blame_map[rel] = cached_blame[rel]

    cache_path.write_text(json.dumps({"head": head, "blame": blame_map}))
    log(f"Blame: {len(blame_map) - computed} cached, {computed} computed, "
        f"{len(candidates)} total md files")
    return blame_map


def main() -> None:
    vault_dir = Path(os.getenv("VAULT_DIR", VAULT_DIR_DEFAULT))
    quartz_dir = Path(os.getenv("QUARTZ_DIR", QUARTZ_DIR_DEFAULT))
    content_dir = quartz_dir / "content"
    whitelist_path = vault_dir / "whitelist.json"

    log("Starting whitelisted sync...")
    log(f"Vault: {vault_dir}")
    log(f"Quartz: {quartz_dir}")

    whitelist = load_whitelist(whitelist_path)
    copied, skipped = sync(vault_dir, content_dir, whitelist)
    log(f"Sync complete. {copied} files copied, {skipped} files skipped.")

    # Per-line blame for git-blame toggle on the site. Cache lives in
    # ~/.cache/ (user-local, never committed) because content/ gets rmtree'd
    # at the start of each sync. CI only needs the output content/blame.json,
    # not the cache.
    cache_dir = Path(os.getenv("XDG_CACHE_HOME", HOME / ".cache")) / "vault-sync"
    cache_dir.mkdir(parents=True, exist_ok=True)
    cache_path = cache_dir / "blame-cache.json"
    blame_map = compute_blame(vault_dir, whitelist, cache_path)
    (content_dir / "blame.json").write_text(json.dumps(blame_map))


if __name__ == "__main__":
    main()
