#!/usr/bin/env bash
# Show diff between restic snapshots
# Usage:
#   restic-diff              # diff latest 2 snapshots
#   restic-diff <newer> <older>  # by index (0=latest) or snapshot ID
set -euo pipefail

if [[ -n "${1:-}" && -n "${2:-}" ]]; then
  snap1=$(restic snapshots --json --no-lock | jq -r "reverse | .[$1].short_id // \"$1\"")
  snap2=$(restic snapshots --json --no-lock | jq -r "reverse | .[$2].short_id // \"$2\"")
  restic diff --no-lock "$snap2" "$snap1"
else
  restic diff --no-lock $(restic snapshots --no-lock --json --latest 2 | jq -r 'map(.short_id) | .[-2:] | join(" ")')
fi
