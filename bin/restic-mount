#!/usr/bin/env bash
# FUSE-mount the current restic repo for interactive browsing.
# Usage: restic-mount [mountpoint]
# Default mountpoint: /tmp/restic-mount/<ctx> (e.g. jarvis-rsyncnet).
# Requires: restic-ctx to set RESTIC_REPOSITORY first.
set -euo pipefail

if [[ -z "${RESTIC_REPOSITORY:-}" ]]; then
  echo "No restic context set. Run: restic-ctx <name>" >&2
  exit 1
fi

mp="${1:-$HOME/mnt/restic-$RESTIC_CTX}"
mkdir -p "$mp"

if mountpoint -q "$mp" 2>/dev/null; then
  echo "Already mounted at $mp"
else
  echo "Mounting $RESTIC_REPOSITORY → $mp"
  restic mount "$mp" &
  for _ in {1..30}; do
    mountpoint -q "$mp" 2>/dev/null && break
    sleep 0.2
  done
fi

echo "Browse: $mp/snapshots/"
