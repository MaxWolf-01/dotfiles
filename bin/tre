#!/usr/bin/env bash
# Colorized, dirs-first tree excluding .git + .gitignore patterns; paginated via less
#
# Options:
#   -e, --exclude PATTERN   Additional pattern to exclude (supports wildcards)
#                           Can be used multiple times: tre -e node_modules -e "*.pyc"
#   All other args are passed through to tree.
set -euo pipefail

root=$(git rev-parse --show-toplevel 2>/dev/null) || root="$PWD"
proj_ign="$root/.gitignore"
glob_ign=$(git config --get core.excludesfile 2>/dev/null | sed "s|^~|$HOME|") || glob_ign="${XDG_CONFIG_HOME:-$HOME/.config}/git/ignore"

# Parse -e/--exclude options, pass remaining args to tree
excludes=()
tree_args=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    -e|--exclude)
      [[ -n "${2:-}" ]] && excludes+=("$2")
      shift 2
      ;;
    --exclude=*)
      excludes+=("${1#--exclude=}")
      shift
      ;;
    -e*)
      excludes+=("${1#-e}")
      shift
      ;;
    *)
      tree_args+=("$1")
      shift
      ;;
  esac
done

# Read and clean patterns from gitignore files
patterns=$(
  grep -hEv '^\s*(#|$)' "$proj_ign" "$glob_ign" 2>/dev/null \
    | sed -E 's@^\./@@; s@/$@@; s@^\*\*/@@' \
    | paste -sd'|' -
) || true

# Build -I argument (always ignore .git)
if [[ -n "$patterns" ]]; then
  patterns=".git|$patterns"
else
  patterns=".git"
fi

# Append manual excludes
for excl in "${excludes[@]}"; do
  patterns="$patterns|$excl"
done

tree -aC -I "$patterns" --dirsfirst "${tree_args[@]}" | less -FRNX
