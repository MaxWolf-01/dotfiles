#!/usr/bin/env bash
# Mirror all GitHub repos for specified accounts to ~/repos/github/<owner>/
# Clones missing repos, fetches existing ones. Safe for working copies.
set -euo pipefail

BASE_DIR="$HOME/repos/github"
ACCOUNTS=("MaxWolf-01" "yapit-tts")

cloned=0
fetched=0
failed=0

for owner in "${ACCOUNTS[@]}"; do
    dir="$BASE_DIR/$owner"
    mkdir -p "$dir"

    echo "=== $owner ==="
    LIMIT=10000
    repos=$(gh repo list "$owner" --limit "$LIMIT" --json name --jq '.[].name')
    count=$(echo "$repos" | grep -c .)
    if [ "$count" -eq "$LIMIT" ]; then
        echo "  WARNING: got exactly $LIMIT repos — results may be truncated!" >&2
    fi
    echo "  $count repos on GitHub"

    while IFS= read -r repo; do
        [ -z "$repo" ] && continue
        repo_dir="$dir/$repo"

        if [ -d "$repo_dir/.git" ]; then
            printf "  fetch  %s ... " "$repo"
            if git -C "$repo_dir" fetch --all --quiet 2>&1; then
                echo "ok"
                ((fetched++)) || true
            else
                echo "FAILED"
                ((failed++)) || true
            fi
        else
            printf "  clone  %s ... " "$repo"
            if gh repo clone "$owner/$repo" "$repo_dir" -- --quiet 2>&1; then
                echo "ok"
                ((cloned++)) || true
            else
                echo "FAILED"
                ((failed++)) || true
            fi
        fi
    done <<< "$repos"
    echo
done

echo "Done: $cloned cloned, $fetched fetched, $failed failed"
